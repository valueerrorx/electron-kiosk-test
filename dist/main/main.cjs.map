{
    "name": "kiosk-test-app",
    "version": "1.0.0",
    "main": "dist/main/main.cjs",
    "author": {
        "name": "Thomas Michael Weissel",
        "email": "valueerror@gmail.com"
    },
    "license": "GPL-3.0",
    "description": "A kiosk test app",
    "type": "module",
    "scripts": {
        "dev": "node scripts/watch.mjs",
        "build": "node scripts/build.mjs && electron-builder -l",
        "build:mac": "node scripts/build.mjs && electron-builder -m",
        "build:win": "node scripts/build.mjs && electron-builder -w"
    },
    "build": {
        "productName": "Kiosk-Test-App",
        "appId": "com.kiosk-test-app.app",
        "asar": {
            "smartUnpack": true
        },
        "afterSign": "scripts/notarize.cjs",
        "asarUnpack": [
            "public"
        ],
        "directories": {
            "output": "../release/${version}"
        },
        "compression": "normal",
        "files": [
            "dist",
            "public"
        ],
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "category": "Utility",
            "icon": "public/icons/256x256.png",
            "artifactName": "${productName}_${version}.${ext}"
        },
        "mac": {
            "icon": "public/icons/icon.png",
            "artifactName": "${productName}_${version}_${arch}.${ext}",
            "hardenedRuntime": true,
            "gatekeeperAssess": false,
            "entitlements": "entitlements.mac.plist",
            "entitlementsInherit": "entitlements.mac.plist",
            "category": "public.app-category.utilities",
            "target": {
                "target": "dmg",
                "arch": [
                    "universal"
                ]
            }
        },
        "dmg": {
            "sign": "true"
        },
        "portable": {
            "useZip": true,
            "unpackDirName": true
        },
        "win": {
            "icon": "public/icons/icon.ico",
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "artifactName": "${productName}_${version}.${ext}",
            "signtoolOptions": {
                "certificateSubjectName": "OSOS Austria"
            }
        }
    },
    "engines": {
        "node": ">=25.8.1"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.5",
        "dotenv": "^17.3.1",
        "electron": "^41.0.3",
        "electron-builder": "^26.8.1",
        "electron-notarize": "^1.2.2",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "vue": "^3.5.30"
    },
    "env": {
        "//": "Used in build scripts",
        "PORT": 3001
    },
    "keywords": [
        "vite",
        "electron",
        "vue3",
        "rollup"
    ],
    "dependencies": {
        "bootstrap": "^5.3.8",
        "electron-log": "^5.4.3",
        "sass": "1.77.6",
        "vue-router": "^5.0.3",
        "vue-sweetalert2": "^5.0.11"
    }
}
